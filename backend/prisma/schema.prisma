generator client {
  provider = "prisma-client-js"
 // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User {
  Id Int @id @default(autoincrement())
  FirstName String
  LastName String 
  Email String @unique
  Password String
  Age Int 
  Gender String
  products Product[]
}


model Product {
  id Int @id @default(autoincrement())
  userId Int
  user User @relation(fields:[userId],references:[Id])
  barcode String @unique
  productName String 
  brands String?
  productQuantity Int
  expiryDate DateTime?
  createdAt DateTime @default(now())
  updatedOn DateTime? @updatedAt
}